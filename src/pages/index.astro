---
import PageLayout from '@/layouts/PageLayout.astro';
import Icon from '@/components/Icon.astro';
import { pathFor } from '@/utils/paths';
import { getYouTubeThumbnail } from '@/utils/youtube';

const base = import.meta.env.BASE_URL;
const featuredVideoUrl = 'https://www.youtube.com/watch?v=O1HHTV9ncFs';
const featuredThumbnail = getYouTubeThumbnail(featuredVideoUrl);
---

<PageLayout
  title="Iglesia Presbiteriana Reformada | Gethsemaní"
  description="Iglesia Presbiteriana Reformada Gethsemaní en Coyoacán. Una iglesia confesional centrada en Cristo, la Palabra y la comunidad."
  canonicalPath="/"
>
  <section class="home-hero">
    <div class="home-hero-copy">
      <p class="overline">Iglesia Presbiteriana Reformada</p>
      <h1>Gethsemaní</h1>
      <p class="hero-summary">
        Existimos para glorificar a Dios mediante la adoración, la predicación fiel de las Escrituras y una
        comunidad formada por la gracia de Jesucristo.
      </p>
      <div class="hero-buttons">
        <a class="button button-white" href={pathFor('/contacto/')}>Planea tu visita <Icon name="arrow" /></a>
        <a class="button button-ghost" href={pathFor('/sermones/')}>Ver sermones</a>
      </div>
      <div class="hero-stats">
        <div><strong>10:30</strong><span>Estudios bíblicos</span></div>
        <div><strong>12:00</strong><span>Culto de adoración</span></div>
        <div><strong>18:00</strong><span>Culto familiar</span></div>
      </div>
    </div>
    <figure class="home-hero-image">
      <img
        src={`${base}images/templo-gethsemani.jpg`}
        alt="Templo de la Iglesia Presbiteriana Reformada Gethsemaní"
        width="1024"
        height="1024"
      />
    </figure>
  </section>

  <section class="intro-band">
    <p>Una congregación histórica con un mensaje que no cambia.</p>
    <div>
      <span>Confesional</span>
      <span>Presbiteriana</span>
      <span>Reformada</span>
    </div>
  </section>

  <section class="content-section welcome-grid">
    <div>
      <p class="overline blue">Bienvenidos</p>
      <h2>Doctrina bíblica.<br />Adoración reverente.<br />Vida en comunidad.</h2>
    </div>
    <div>
      <p class="large-copy">
        Creemos que la iglesia debe ser más que un evento dominical. Es una familia que aprende, adora, sirve y da
        testimonio de Cristo en medio de la ciudad.
      </p>
      <a class="arrow-link" href={pathFor('/nosotros/')}>Conoce nuestra historia <Icon name="arrow" /></a>
    </div>
  </section>

  <section class="belief-preview">
    <div class="belief-preview-head">
      <div>
        <p class="overline">El corazón de nuestra fe</p>
        <h2>Una fe bíblica, histórica y reformada.</h2>
      </div>
      <a class="button button-blue" href={pathFor('/lo-que-creemos/')}>
        Explorar lo que creemos <Icon name="arrow" />
      </a>
    </div>
    <div class="belief-pillars belief-pillars--five">
      <article>
        <span class="icon-badge" aria-hidden="true"><Icon name="scripture" /></span>
        <h3>Sola Scriptura</h3>
        <p>Solo la Escritura</p>
      </article>
      <article>
        <span class="icon-badge" aria-hidden="true"><Icon name="grace" /></span>
        <h3>Sola Gratia</h3>
        <p>Solo por gracia</p>
      </article>
      <article>
        <span class="icon-badge" aria-hidden="true"><Icon name="faith" /></span>
        <h3>Sola Fide</h3>
        <p>Solo por la fe</p>
      </article>
      <article>
        <span class="icon-badge" aria-hidden="true"><Icon name="christ" /></span>
        <h3>Solus Christus</h3>
        <p>Solo Cristo</p>
      </article>
      <article>
        <span class="icon-badge" aria-hidden="true"><Icon name="glory" /></span>
        <h3>Soli Deo Gloria</h3>
        <p>Solo a Dios la gloria</p>
      </article>
    </div>
  </section>

  <section class="media-section">
    <div>
      <p class="overline blue">Crece en la Palabra</p>
      <h2>Sermones, reflexiones<br />y recursos para ti.</h2>
    </div>
    <div class="media-cards">
      <a href={pathFor('/sermones/')}>
        <span class="icon-badge" aria-hidden="true"><Icon name="play" /></span>
        <div><small>Escucha</small><strong>Sermones recientes</strong></div>
        <b aria-hidden="true">→</b>
      </a>
      <a href={pathFor('/reflexiones/')}>
        <span class="icon-badge" aria-hidden="true"><Icon name="spark" /></span>
        <div><small>Lee</small><strong>Reflexiones bíblicas</strong></div>
        <b aria-hidden="true">→</b>
      </a>
      <a href={pathFor('/recursos/')}>
        <span class="icon-badge" aria-hidden="true"><Icon name="scroll" /></span>
        <div><small>Explora</small><strong>Biblioteca de recursos</strong></div>
        <b aria-hidden="true">→</b>
      </a>
    </div>
  </section>

  <section class="channel-section">
    <div class="channel-copy">
      <p class="overline">Canal oficial</p>
      <h2>Predicación para escuchar durante la semana.</h2>
      <p>Sermones, cultos y conferencias publicados por nuestra congregación.</p>
      <a class="button button-white" href={pathFor('/sermones/')}>
        Ver todos los videos <Icon name="arrow" />
      </a>
    </div>
    <a class="channel-feature" href={featuredVideoUrl} target="_blank" rel="noopener">
      <img src={featuredThumbnail} alt="La murmuración, estudio bíblico del 19 de julio de 2026" />
      <span class="play-icon" aria-hidden="true"><Icon name="play" /></span>
      <div>
        <small>Estudio bíblico reciente</small>
        <strong>La murmuración</strong>
        <p>19 de julio de 2026 · 18:00 horas</p>
      </div>
    </a>
  </section>

  <section class="visit-cta">
    <div class="visit-cta-media" aria-hidden="true">
      <img
        src={`${base}images/templo-gethsemani.jpg`}
        alt=""
        width="1024"
        height="768"
        loading="lazy"
      />
    </div>
    <div class="visit-cta-copy">
      <p class="overline">Este domingo</p>
      <h2>Hay un lugar para ti.</h2>
      <p>
        Únete a nuestra familia en adoración. Te esperamos en Cuauhtémoc 117, esquina con Allende, Colonia Del Carmen,
        Coyoacán.
      </p>
      <ul class="visit-cta-times">
        <li><strong>9:30</strong><span>Aposento Alto</span></li>
        <li><strong>10:30</strong><span>Escuela Bíblica Dominical</span></li>
        <li><strong>12:00</strong><span>Culto de adoración</span></li>
        <li><strong>18:00</strong><span>Culto familiar</span></li>
      </ul>
      <div class="visit-cta-actions">
        <a class="button button-white" href={pathFor('/contacto/')}>
          Cómo llegar <Icon name="map" />
        </a>
        <a class="button button-ghost" href="tel:+525555543467">
          Llamar <Icon name="phone" />
        </a>
      </div>
    </div>
  </section>
</PageLayout>
