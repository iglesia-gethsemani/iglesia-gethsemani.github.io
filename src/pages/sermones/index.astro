---
import PageLayout from '@/layouts/PageLayout.astro';
import YouTubeEmbed from '@/components/YouTubeEmbed.astro';
import { latestLiveVideo, latestShortVideo, regularVideos } from '@/data/youtube';

const visibleRegularVideos = regularVideos.slice(0, 10);
---

<PageLayout
  title="Sermones"
  description="Sermones, cultos y conferencias de la Iglesia Presbiteriana Reformada Gethsemaní en YouTube."
  canonicalPath="/sermones/"
>
  <header class="page-hero">
    <div>
      <p class="overline">Predicación expositiva</p>
      <h1>Escucha<br /><em>la Palabra.</em></h1>
    </div>
    <p>
      Mensajes recientes de nuestra congregación para conocer a Dios, comprender las Escrituras y vivir el evangelio.
    </p>
  </header>

  <section class="youtube-library">
    <div class="youtube-library-head">
      <div>
        <p class="overline">Canal oficial de YouTube</p>
        <h2>Cultos y sermones</h2>
      </div>
      <div>
        <p>Una selección del contenido publicado por la Iglesia Presbiteriana Reformada Gethsemaní.</p>
        <a
          class="button button-white"
          href="https://www.youtube.com/@i.p.r.m.gethsemani"
          target="_blank"
          rel="noopener"
        >
          Abrir el canal <b>↗</b>
        </a>
      </div>
    </div>

    <div class="youtube-latest-grid">
      <article class="youtube-latest-card">
        <div class="youtube-card-head">
          <p class="overline">{latestLiveVideo.label}</p>
          <a href="https://www.youtube.com/@i.p.r.m.gethsemani/streams" target="_blank" rel="noopener">
            Ver transmisiones ↗
          </a>
        </div>
        <YouTubeEmbed url={latestLiveVideo.url} title={latestLiveVideo.title} />
        <h3>{latestLiveVideo.title}</h3>
        <span>{latestLiveVideo.detail}</span>
      </article>

      <article class="youtube-latest-card youtube-short-card">
        <div class="youtube-card-head">
          <p class="overline">{latestShortVideo.label}</p>
          <a href="https://www.youtube.com/@i.p.r.m.gethsemani/shorts" target="_blank" rel="noopener">
            Ver Shorts ↗
          </a>
        </div>
        <div class="youtube-short-content">
          <YouTubeEmbed url={latestShortVideo.url} title={latestShortVideo.title} variant="short" />
          <div>
            <h3>{latestShortVideo.title}</h3>
            <p>Contenido breve publicado en el canal oficial de la iglesia.</p>
          </div>
        </div>
      </article>
    </div>

    <div class="youtube-archive-head">
      <div>
        <p class="overline">Publicaciones recientes</p>
        <h2>Los últimos 10 videos</h2>
      </div>
      <p>Estudios bíblicos, sermones, música y programas publicados recientemente en el canal.</p>
    </div>

    <div class="youtube-video-grid">
      {
        visibleRegularVideos.map((video) => (
          <article>
            <YouTubeEmbed url={video.url} title={video.title} />
            <p>{video.label}</p>
            <h3>{video.title}</h3>
            {video.detail && <span>{video.detail}</span>}
          </article>
        ))
      }
    </div>
  </section>
</PageLayout>
