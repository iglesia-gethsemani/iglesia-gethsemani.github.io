---
import PageLayout from '@/layouts/PageLayout.astro';
import { elders } from '@/data/elders';

const base = import.meta.env.BASE_URL;
const sortedElders = [...elders].sort((a, b) => a.order - b.order);
---

<PageLayout
  title="Nosotros"
  description="Conoce la misión, convicciones y consistorio de la Iglesia Presbiteriana Reformada Gethsemaní en Coyoacán."
  canonicalPath="/nosotros/"
>
  <header class="page-hero">
    <div>
      <p class="eyebrow">Quiénes somos</p>
      <h1>Una iglesia para<br /><em>la gloria de Dios.</em></h1>
    </div>
    <p>
      Una comunidad reformada que busca vivir el evangelio con fidelidad, reverencia y amor en el corazón de
      Coyoacán.
    </p>
  </header>

  <section class="section story-grid">
    <div>
      <p class="eyebrow">Nuestra misión</p>
      <h2>Arraigados en la verdad,<br />creciendo en gracia.</h2>
    </div>
    <div class="prose">
      <p class="lead">
        La Iglesia Presbiteriana Reformada Gethsemaní existe para glorificar a Dios mediante la predicación fiel de
        la Palabra, la adoración reverente y la formación de discípulos conforme a las Escrituras.
      </p>
      <p>
        Formamos parte de la tradición reformada histórica: confesamos a Cristo como cabeza de la Iglesia y
        reconocemos en la Biblia nuestra regla de fe y vida.
      </p>
    </div>
  </section>

  <section class="values-section">
    <div class="section-heading centered">
      <p class="eyebrow">Lo que nos distingue</p>
      <h2>Nuestras convicciones</h2>
    </div>
    <div class="values-grid">
      <article>
        <span>S</span>
        <h3>Sola Scriptura</h3>
        <p>La Escritura es la única autoridad infalible para la fe y la vida.</p>
      </article>
      <article>
        <span>C</span>
        <h3>Solus Christus</h3>
        <p>Cristo es nuestro único mediador, salvador y cabeza de la Iglesia.</p>
      </article>
      <article>
        <span>G</span>
        <h3>Soli Deo Gloria</h3>
        <p>Toda nuestra vida y adoración existen para la gloria de Dios.</p>
      </article>
    </div>
  </section>

  <section class="section leadership-section">
    <div class="section-heading">
      <p class="eyebrow">Liderazgo</p>
      <h2>Nuestro consistorio</h2>
    </div>
    <div class="elders-grid">
      {
        sortedElders.length > 0 ? (
          sortedElders.map((elder) => (
            <article class="elder-card">
              <div class="elder-photo">
                <img src={`${base}${elder.photo.replace(/^\//, '')}`} alt={`Retrato de ${elder.name}`} />
              </div>
              <h3>{elder.name}</h3>
              <p>{elder.role}</p>
            </article>
          ))
        ) : (
          <p class="empty-message">Próximamente presentaremos aquí a nuestro consistorio.</p>
        )
      }
    </div>
  </section>
</PageLayout>
