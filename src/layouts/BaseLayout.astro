---
import ChatWidget from '@/components/ChatWidget.astro';
import { assetVersion } from '@/utils/assets';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  canonicalPath?: string;
  ogType?: 'website' | 'article';
}

const {
  title = 'Iglesia Presbiteriana Reformada Gethsemaní',
  description = 'Iglesia Presbiteriana Reformada Gethsemaní en Coyoacán. Una iglesia confesional centrada en Cristo y en su Palabra.',
  image = '/images/templo-gethsemani.jpg',
  canonicalPath = '/',
  ogType = 'website',
} = Astro.props;

const site = Astro.site?.toString().replace(/\/$/, '') ?? 'https://iglesia-gethsemani.github.io';
const base = import.meta.env.BASE_URL;
const pageTitle = title.includes('Gethsemaní') ? title : `${title} | Iglesia Presbiteriana Reformada Gethsemaní`;
const canonicalUrl = new URL(canonicalPath.replace(/^\//, ''), `${site}${base}`).href;
const ogImage = image.startsWith('http') ? image : new URL(image.replace(/^\//, ''), `${site}${base}`).href;
const logoUrl = new URL('images/logo-gethsemani.png', `${site}${base}`).href;
const churchSchema = {
  '@context': 'https://schema.org',
  '@type': 'Church',
  name: 'Iglesia Presbiteriana Reformada Gethsemaní',
  url: `${site}${base === '/' ? '/' : base}`,
  logo: logoUrl,
  sameAs: [
    'https://www.facebook.com/iprm.gethsemani',
    'https://www.youtube.com/@i.p.r.m.gethsemani',
  ],
};
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="description" content={description} />
    <meta name="google-site-verification" content="RbaQ1oJ7DiOYhGZav_rs-bkQ42MVvWKnDLZxa6V6KWg" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:type" content={ogType} />
    <meta property="og:locale" content="es_MX" />
    <meta property="og:site_name" content="Iglesia Presbiteriana Reformada Gethsemaní" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <link rel="icon" href={`${base}favicon.ico`} sizes="32x32" />
    <link rel="icon" type="image/png" href={`${base}favicon-256.png`} sizes="256x256" />
    <link rel="apple-touch-icon" href={`${base}apple-touch-icon.png`} sizes="180x180" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Source+Serif+4:ital,wght@0,600;1,500&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href={`${base}styles/global.css?v=${assetVersion}`} />
    <script type="application/ld+json" set:html={JSON.stringify(churchSchema)} />
  </head>
  <body>
    <a class="skip-link" href="#contenido">Ir al contenido</a>
    <div class="topbar">
      <div>Cuauhtémoc 117 · Coyoacán, CDMX</div>
      <div>Domingos desde las 9:30 h</div>
    </div>
    <slot name="header" />
    <main id="contenido">
      <slot />
    </main>
    <slot name="footer" />
    <ChatWidget />
    <script is:inline src={`${base}scripts/site.js?v=${assetVersion}`} defer></script>
  </body>
</html>
