---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  canonicalPath?: string;
}

const props = Astro.props;
---

<BaseLayout {...props}>
  <Header slot="header" />
  <slot />
  <Footer slot="footer" />
</BaseLayout>
