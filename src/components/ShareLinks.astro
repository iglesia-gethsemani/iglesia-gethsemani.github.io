---
import Icon from '@/components/Icon.astro';

interface Props {
  url: string;
  title: string;
  description?: string;
  passage?: string;
  body?: string;
}

const { url, title, description = '', passage = '', body = '' } = Astro.props;

function toPlainText(markdown: string): string {
  return markdown
    .replace(/\r\n/g, '\n')
    .replace(/!\[[^\]]*\]\([^)]+\)/g, '')
    .replace(/\[([^\]]+)\]\([^)]+\)/g, '$1')
    .replace(/[`*_~>#]/g, '')
    .replace(/^\s*[-*+]\s+/gm, '• ')
    .replace(/\n{3,}/g, '\n\n')
    .trim();
}

const plainBody = toPlainText(body);
const parts = [
  title,
  passage ? `“${passage}”` : '',
  plainBody,
  description && description !== title && description !== passage ? description : '',
].filter(Boolean);

const fullText = parts.join('\n\n');
const shareMessage = `${fullText}\n\n———\nLéela en la página de la iglesia (vista completa):\n${url}`;
const facebookQuote = fullText.slice(0, 500);

// Desktop/fallback Facebook dialog. On mobile we prefer the system share sheet via JS.
const facebookHref = `https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(url)}&quote=${encodeURIComponent(facebookQuote)}`;
const whatsappHref = `https://wa.me/?text=${encodeURIComponent(shareMessage)}`;
const xHref = `https://twitter.com/intent/tweet?url=${encodeURIComponent(url)}&text=${encodeURIComponent(`${title}${passage ? ` — ${passage}` : ''}`)}`;
---

<div
  class="share-box"
  data-share-root
  data-share-url={url}
  data-share-title={title}
  data-share-text={shareMessage}
>
  <p class="share-label">Compartir esta reflexión</p>
  <p class="share-note">
    <small>Nota: Al compartir, se incluirá un enlace a la página de la iglesia con la reflexión completa.</small>
  </p>
  <div class="share-actions">
    <button
      class="share-btn share-btn--primary"
      type="button"
      data-share-native
      aria-label="Compartir reflexión con el menú del dispositivo"
    >
      <Icon name="share" />
      <span>Compartir</span>
    </button>
    <button
      class="share-btn"
      type="button"
      data-share-facebook
      data-facebook-href={facebookHref}
      aria-label="Compartir en Facebook"
    >
      <Icon name="facebook" />
      <span>Facebook</span>
    </button>
    <a
      class="share-btn"
      href={whatsappHref}
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Compartir en WhatsApp"
    >
      <Icon name="whatsapp" />
      <span>WhatsApp</span>
    </a>
    <a class="share-btn" href={xHref} target="_blank" rel="noopener noreferrer" aria-label="Compartir en X">
      <Icon name="x" />
      <span>X</span>
    </a>
    <button
      class="share-btn"
      type="button"
      data-copy-link={url}
      data-copy-text={shareMessage}
      aria-label="Copiar reflexión y enlace"
    >
      <Icon name="link" />
      <span data-copy-label>Copiar texto y enlace</span>
    </button>
  </div>
  <p class="share-feedback" data-share-feedback hidden></p>
</div>
